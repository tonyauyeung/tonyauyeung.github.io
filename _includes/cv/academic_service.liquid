<ul class="card-text font-weight-light list-group list-group-flush">
  {% for item in academic_service.items %}
    <li class="list-group-item">
      <h5 class="font-italic">{{ item.role }}</h5>
      {% if item.details %}
        <div class="academic-service-details">{{ item.details | markdownify | replace: '<p>', '' | replace: '</p>', '' | strip }}</div>
      {% endif %}
      {% if item.items %}
        {% for subitem in item.items %}
          {% if subitem.award %}
            <div class="academic-service-award"><strong>award:</strong> {{ subitem.award }}</div>
          {% endif %}
        {% endfor %}
        {% assign plain_subitem_count = 0 %}
        {% for subitem in item.items %}
          {% unless subitem.award %}
            {% assign plain_subitem_count = plain_subitem_count | plus: 1 %}
          {% endunless %}
        {% endfor %}
        {% if plain_subitem_count > 0 %}
          <ul class="subitems">
            {% for subitem in item.items %}
              {% unless subitem.award %}
                <li>
                  <span class="subitem">{{ subitem }}</span>
                </li>
              {% endunless %}
            {% endfor %}
          </ul>
        {% endif %}
      {% endif %}
    </li>
  {% endfor %}
</ul>
